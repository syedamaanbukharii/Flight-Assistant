# ===========================================================================
# Flight & Travel Assistant — environment configuration
# Copy to `.env` and fill in your values:  cp .env.example .env
# NEVER commit your real .env file. Secrets belong only in .env.
# ===========================================================================

# --- Application ---------------------------------------------------------- #
APP_ENV=development          # development | staging | production
DEBUG=false
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
HOST=0.0.0.0
PORT=8000

# --- LLM (Groq) ----------------------------------------------------------- #
# Get a key at https://console.groq.com . Without it the assistant still runs
# but falls back to a deterministic, non-LLM planner.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.2
GROQ_MAX_TOKENS=1024
GROQ_TIMEOUT_SECONDS=30

# --- Flight & Hotel provider (RapidAPI Sky Scrapper) ---------------------- #
# Subscribe at https://rapidapi.com/apiheya/api/sky-scrapper . Without a key,
# flight and hotel search are disabled but the rest of the system works.
RAPIDAPI_KEY=
RAPIDAPI_HOST=sky-scrapper.p.rapidapi.com

# --- HTTP client behaviour ------------------------------------------------ #
HTTP_TIMEOUT_SECONDS=20
HTTP_MAX_RETRIES=2

# --- Database ------------------------------------------------------------- #
# Defaults to a SQLite file inside backend/data/ (resolved from the package
# location, so it works regardless of the working directory). Uncomment to
# override. Switch to PostgreSQL by changing this URL only, e.g.:
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/flight_assistant
# DATABASE_URL=sqlite:///backend/data/flight_assistant.db

# --- Localisation defaults ------------------------------------------------ #
DEFAULT_CURRENCY=INR
DEFAULT_MARKET=en-US
DEFAULT_COUNTRY=IN

# --- Coupons -------------------------------------------------------------- #
# Defaults to backend/data/coupons.seed.json (resolved from the package
# location). Uncomment to override.
# COUPON_SEED_PATH=backend/data/coupons.seed.json
# Comma-separated list of lightweight public coupon pages to scrape (optional).
COUPON_SOURCES=
COUPON_USE_PLAYWRIGHT=false
COUPON_REFRESH_ENABLED=true
COUPON_REFRESH_INTERVAL_MINUTES=360

# --- Scheduler ------------------------------------------------------------ #
ENABLE_SCHEDULER=true

# --- API ------------------------------------------------------------------ #
# Comma-separated allowed origins for CORS (use specific origins in production).
CORS_ALLOW_ORIGINS=*
MAX_RESULTS=10

# --- Frontend (Streamlit) ------------------------------------------------- #
BACKEND_URL=http://localhost:8000
FRONTEND_TIMEOUT=60
